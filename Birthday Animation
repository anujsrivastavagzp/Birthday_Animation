<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Happy Birthday Anuj</title>

<style>
body {
  margin: 0;
  padding: 0;
  text-align: center;
  background: linear-gradient(to right, #ff758c, #ff7eb3);
  font-family: Arial;
  overflow: hidden;
}

.container {
  margin-top: 50px;
}

img {
  width: 180px;
  height: 180px;
  border-radius: 50%;
  border: 5px solid white;
  box-shadow: 0 0 20px white;
}

h1 {
  font-size: 40px;
  color: white;
  animation: glow 1s infinite alternate;
}

p {
  color: white;
  font-size: 20px;
}

@keyframes glow {
  from { text-shadow: 0 0 10px white; }
  to { text-shadow: 0 0 25px yellow; }
}

/* Balloons */
.balloons span {
  position: absolute;
  width: 40px;
  height: 60px;
  background: red;
  border-radius: 50%;
  animation: float 6s linear infinite;
}

@keyframes float {
  0% { transform: translateY(100vh); }
  100% { transform: translateY(-10vh); }
}
</style>
</head>

<body>

<div class="container">
  <img src="your-photo.jpg" alt="Anuj">
  <h1>🎉 Happy Birthday 🎂</h1>
  <p>Anuj Srivastava</p>
</div>

<div class="balloons">
  <span style="left:10%; animation-delay:0s;"></span>
  <span style="left:30%; animation-delay:2s;"></span>
  <span style="left:50%; animation-delay:4s;"></span>
  <span style="left:70%; animation-delay:1s;"></span>
  <span style="left:90%; animation-delay:3s;"></span>
</div>

</body>
</html>